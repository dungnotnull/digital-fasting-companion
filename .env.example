# Digital Fasting Companion - Environment Configuration

# =================
# Core Settings
# =================
APP_NAME=digital-fasting-companion
DEBUG=false
LOG_LEVEL=INFO

# =================
# Database
# =================
DB_PATH=app.db
DB_KEY=your-256-bit-encryption-key-change-this

# =================
# Intervention Thresholds
# =================
TIER1_MIN_SCORE=0.4
TIER1_MAX_SCORE=0.6
TIER2_MIN_SCORE=0.6
TIER2_MAX_SCORE=0.8
TIER3_MIN_SCORE=0.8
TIER3_MAX_SCORE=1.0

# Time thresholds (minutes)
SESSION_THRESHOLD_AI=120
SESSION_THRESHOLD_SOCIAL=180

# =================
# Fatiguedetection Settings
# =================
FEATURE_WINDOW_SECONDS=300  # 5 minutes
PREDICTION_INTERVAL_SECONDS=60
ONLINE_LEARNING_WEEKS=1

# =================
# Ollama Settings (Local SLM)
# =================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=tinyllama
OLLAMA_TIMEOUT_SECONDS=30

# =================
# External LLM APIs (Optional)
# =================
# CLAUDE_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GARMIN_CONNECT_PASSWORD=...

# =================
# Monitoring Settings
# =================
KEYSTROKE_SAMPLE_INTERVAL_MS=100
SCREEN_TIME_POLL_INTERVAL_SECONDS=30
