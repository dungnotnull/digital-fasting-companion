{
  "manifest_version": 3,
  "name": "Digital Fasting Companion",
  "version": "0.1.0",
  "description": "Monitor AI tool and social media usage to prevent digital fatigue. Enforces healthy offline breaks.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "nativeMessaging",
    "webNavigation"
  ],
  "host_permissions": [
    "*://*.openai.com/*",
    "*://*.anthropic.com/*",
    "*://*.claude.ai/*",
    "*://*.bard.google.com/*",
    "*://chat.openai.com/*",
    "*://*.perplexity.ai/*",
    "*://*.poe.com/*",
    "*://*.facebook.com/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "*://*.instagram.com/*",
    "*://*.tiktok.com/*",
    "*://*.youtube.com/*",
    "*://*.reddit.com/*",
    "*://*.linkedin.com/*",
    "*://*.discord.com/*",
    "*://*.telegram.org/*",
    "*://*.twitch.tv/*",
    "*://*.netflix.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.openai.com/*",
        "*://*.anthropic.com/*",
        "*://*.claude.ai/*",
        "*://chat.openai.com/*",
        "*://*.facebook.com/*",
        "*://*.twitter.com/*",
        "*://*.youtube.com/*",
        "*://*.reddit.com/*",
        "*://*.tiktok.com/*",
        "*://*.instagram.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
